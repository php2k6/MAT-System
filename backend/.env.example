# Database connection URL
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/mat_system

# Frontend origin (used for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Set to true when backend is exposed via HTTPS (e.g. ngrok) so cross-origin cookies work
COOKIE_SECURE=false

# JWT
JWT_SECRET_KEY=changethissecretkey
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Fyers — get these from myapi.fyers.in after creating an app
FYERS_APP_ID=YOURAPPID-100
FYERS_SECRET_KEY=yoursecretkey
FYERS_REDIRECT_URI=https://yourdomain.com/api/broker/callback

# Redis live-price cache (leave empty to use in-memory fallback)
REDIS_URL=redis://localhost:6379/0
REDIS_PRICE_TTL_SECONDS=900
LIVE_PRICE_STALE_AFTER_SECONDS=90
LIVE_PRICE_REFRESH_SECONDS=15
FYERS_QUOTES_CHUNK_SIZE=50

# MAT engine runtime tuning (no code change required)
# Keep MAT_CASH_BUFFER in [0.0, 0.5]. 0.005 means 0.5% cash reserve.
MAT_CASH_BUFFER=0.005
# Brokerage rate in percentage; 0.3 means 0.3% (engine also caps to Rs 20)
MAT_BROKERAGE_RATE=0.3
MAT_STT_SELL_RATE=0.001
MAT_EXCHANGE_CHARGE_RATE=0.0000325
MAT_SEBI_CHARGE_RATE=0.000001
MAT_GST_RATE=0.18
MAT_STAMP_DUTY_BUY_RATE=0.00015
# Max seconds to wait for order fills before marking timeout
MAT_ORDER_WAIT_SECONDS=120
# Poll interval (seconds) for order status checks
MAT_ORDER_POLL_INTERVAL_SECONDS=5
# Minimum delay (seconds) between order placements (SEBI pacing guard)
MAT_ORDER_MIN_INTERVAL_SECONDS=0.11
# Candidate pool multiplier: top N * multiplier scanned before UC/filters
MAT_CANDIDATE_POOL_MULTIPLIER=1.5

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=backend.log
REBALANCE_LOG_FILE_NAME=rebalancing.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# Testing/manual trigger endpoints (set true in local dev only)
ENABLE_TESTING_ENDPOINTS=false

# Enable/disable APScheduler jobs globally
ENABLE_SCHEDULER=true

# Scheduler timings
SCHEDULER_TIMEZONE=Asia/Kolkata
QUEUE_REBALANCE_HOUR_IST=9
QUEUE_REBALANCE_MINUTE_IST=0
DRAIN_REBALANCE_HOUR_IST=12
DRAIN_REBALANCE_MINUTE_IST=0
MARKET_OPEN_HOUR_IST=9
MARKET_OPEN_MINUTE_IST=15
MARKET_CLOSE_HOUR_IST=15
MARKET_CLOSE_MINUTE_IST=30

# EOD mark-to-market job (IST)
EOD_MTM_HOUR_IST=15
EOD_MTM_MINUTE_IST=40

# Broker reconciliation snapshot at/after market open (IST)
RECONCILE_OPEN_HOUR_IST=9
RECONCILE_OPEN_MINUTE_IST=20

# Yahoo daily DB sync (StockPrice update from Yahoo Finance)
ENABLE_YAHOO_DAILY_SYNC=false
YAHOO_DAILY_SYNC_HOUR_IST=19
YAHOO_DAILY_SYNC_MINUTE_IST=0
YAHOO_REFERENCE_TICKER=NIFTYBEES.NS
YAHOO_BASE_DATE=2015-01-01
YAHOO_SPLIT_LOOKBACK_DAYS=5
YAHOO_VOLATILITY_WINDOW=252
YAHOO_ANNUALISE_VOL=false
YAHOO_API_DELAY_SECONDS=0.2
YAHOO_FETCH_RETRIES=3
YAHOO_FETCH_RETRY_DELAY_SECONDS=1.0
# If a symbol has internal date gaps larger than this, force full refetch.
YAHOO_MAX_INTERNAL_GAP_DAYS=40
