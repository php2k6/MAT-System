# Database connection URL
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/mat_system

# Frontend origin (used for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Set to true when backend is exposed via HTTPS (e.g. ngrok) so cross-origin cookies work
COOKIE_SECURE=false

# JWT
JWT_SECRET_KEY=changethissecretkey
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Fyers — get these from myapi.fyers.in after creating an app
FYERS_APP_ID=YOURAPPID-100
FYERS_SECRET_KEY=yoursecretkey
FYERS_REDIRECT_URI=https://yourdomain.com/api/broker/callback
