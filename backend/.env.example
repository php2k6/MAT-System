# Database connection URL
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/mat_system

# Frontend origin (used for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Set to true when backend is exposed via HTTPS (e.g. ngrok) so cross-origin cookies work
COOKIE_SECURE=false

# JWT
JWT_SECRET_KEY=changethissecretkey
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Fyers — get these from myapi.fyers.in after creating an app
FYERS_APP_ID=YOURAPPID-100
FYERS_SECRET_KEY=yoursecretkey
FYERS_REDIRECT_URI=https://yourdomain.com/api/broker/callback

# Redis live-price cache (leave empty to use in-memory fallback)
REDIS_URL=redis://localhost:6379/0
REDIS_PRICE_TTL_SECONDS=900
LIVE_PRICE_STALE_AFTER_SECONDS=90
LIVE_PRICE_REFRESH_SECONDS=15

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=backend.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# Testing/manual trigger endpoints (set true in local dev only)
ENABLE_TESTING_ENDPOINTS=false

# Enable/disable APScheduler jobs globally
ENABLE_SCHEDULER=true

# Scheduler timings
SCHEDULER_TIMEZONE=Asia/Kolkata
QUEUE_REBALANCE_HOUR_IST=9
QUEUE_REBALANCE_MINUTE_IST=0
DRAIN_REBALANCE_HOUR_IST=12
DRAIN_REBALANCE_MINUTE_IST=0
MARKET_OPEN_HOUR_IST=9
MARKET_OPEN_MINUTE_IST=15
MARKET_CLOSE_HOUR_IST=15
MARKET_CLOSE_MINUTE_IST=30

# EOD mark-to-market job (IST)
EOD_MTM_HOUR_IST=15
EOD_MTM_MINUTE_IST=40
