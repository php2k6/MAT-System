# =====================================================================
# MAT System Environment Configuration
# =====================================================================
# Copy this file to .env and fill in your actual values

# ─────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────
DB_USER=matuser
DB_PASSWORD=matpass
DB_NAME=mat_system
DATABASE_URL=postgresql://matuser:matpass@postgres:5432/mat_system

# ─────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION (for live prices + caching)
# ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────────────
# EVOLUTION API (WhatsApp Notifications via Docker)
# ─────────────────────────────────────────────────────────────────────
# Setup:
# 1. docker-compose up --build
# 2. Open http://localhost:8080
# 3. Scan QR code with WhatsApp → get API Key
# 4. Paste API Key below
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=<paste-your-evolution-api-key-here>

# Optional: Evolution API instance identifier (if your setup needs it)
EVOLUTION_API_INSTANCE=mat-system

# ─────────────────────────────────────────────────────────────────────
# FYERS BROKER INTEGRATION
# ─────────────────────────────────────────────────────────────────────
# Get these from Fyers Developer Dashboard
# https://api.fyers.in/dev
FYERS_APP_ID=<your-fyers-app-id>
FYERS_SECRET_KEY=<your-fyers-secret-key>
FYERS_REDIRECT_URI=http://localhost:8000/api/auth/fyers/callback

# ─────────────────────────────────────────────────────────────────────
# JWT (JSON Web Token) Configuration
# ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=<change-this-to-a-secure-random-string-in-production>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION
# ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost
COOKIE_SECURE=false

# ─────────────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=backend.log
REBALANCE_LOG_FILE_NAME=rebalancing.log

# ─────────────────────────────────────────────────────────────────────
# SCHEDULER TIMING (IST - Indian Standard Time)
# ─────────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Asia/Kolkata

# Pre-market: queue new rebalances
QUEUE_REBALANCE_HOUR_IST=9
QUEUE_REBALANCE_MINUTE_IST=0

# Mid-market: execute queued rebalances
DRAIN_REBALANCE_HOUR_IST=12
DRAIN_REBALANCE_MINUTE_IST=0

# Market hours check
MARKET_OPEN_HOUR_IST=9
MARKET_OPEN_MINUTE_IST=15
MARKET_CLOSE_HOUR_IST=15
MARKET_CLOSE_MINUTE_IST=30

# EOD valuation
EOD_MTM_HOUR_IST=19
EOD_MTM_MINUTE_IST=15

# Broker reconciliation
RECONCILE_OPEN_HOUR_IST=9
RECONCILE_OPEN_MINUTE_IST=20

# ─────────────────────────────────────────────────────────────────────
# MAT ENGINE CONFIGURATION (Momentum Rebalance)
# ─────────────────────────────────────────────────────────────────────
MAT_CASH_BUFFER=0.01
MAT_ORDER_WAIT_SECONDS=120
MAT_ORDER_POLL_INTERVAL_SECONDS=5
MAT_ORDER_MIN_INTERVAL_SECONDS=0.11
MAT_CANDIDATE_POOL_MULTIPLIER=1.5

# Transaction costs
MAT_BROKERAGE_RATE=0.0
MAT_STT_SELL_RATE=0.001
MAT_EXCHANGE_CHARGE_RATE=0.0000325
MAT_SEBI_CHARGE_RATE=0.000001
MAT_GST_RATE=0.18
MAT_STAMP_DUTY_BUY_RATE=0.00015

# ─────────────────────────────────────────────────────────────────────
# OPERATIONAL FLAGS
# ─────────────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true
ENABLE_TESTING_ENDPOINTS=false
ENABLE_YAHOO_DAILY_SYNC=true

# ─────────────────────────────────────────────────────────────────────
# WEBSOCKET TUNING
# ─────────────────────────────────────────────────────────────────────
WS_PRICE_POLL_INTERVAL=0.1
WS_PORTFOLIO_REFRESH_INTERVAL=60.0

